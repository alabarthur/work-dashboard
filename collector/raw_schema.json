{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "raw_data",
  "type": "object",
  "required": ["collected_at", "sources", "items"],
  "additionalProperties": false,
  "properties": {
    "collected_at": {
      "type": "string",
      "description": "ISO-8601 timestamp (with timezone offset) when collection finished"
    },
    "sources": {
      "type": "object",
      "required": ["teams", "calendar", "email", "notion", "tfs"],
      "additionalProperties": false,
      "properties": {
        "teams": { "$ref": "#/definitions/sourceHealth" },
        "calendar": { "$ref": "#/definitions/sourceHealth" },
        "email": { "$ref": "#/definitions/sourceHealth" },
        "notion": { "$ref": "#/definitions/sourceHealth" },
        "tfs": { "$ref": "#/definitions/sourceHealth" }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/definitions/item" }
    }
  },
  "definitions": {
    "sourceHealth": {
      "type": "object",
      "required": ["ok"],
      "additionalProperties": false,
      "properties": {
        "ok": { "type": "boolean" },
        "error": { "type": ["string", "null"] }
      }
    },
    "person": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": ["string", "null"] },
        "email": { "type": ["string", "null"] }
      }
    },
    "meeting": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "start": { "type": ["string", "null"] },
        "end": { "type": ["string", "null"] },
        "is_organizer": { "type": ["boolean", "null"] },
        "response": { "type": ["string", "null"] }
      }
    },
    "item": {
      "type": "object",
      "required": ["id", "source", "type", "title"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "source": {
          "type": "string",
          "enum": ["teams", "outlook_email", "calendar", "notion", "tfs"]
        },
        "type": {
          "type": "string",
          "enum": ["mention", "dm", "email", "meeting", "task"]
        },
        "title": { "type": "string" },
        "snippet": { "type": ["string", "null"] },
        "thread_id": { "type": ["string", "null"] },
        "from": { "$ref": "#/definitions/person" },
        "url": { "type": ["string", "null"] },
        "created_at": { "type": ["string", "null"] },
        "due_at": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "has_dependency": { "type": "boolean" },
        "meeting": { "$ref": "#/definitions/meeting" }
      }
    }
  }
}
